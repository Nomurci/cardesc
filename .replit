modules = ["python-3.11"]
[agent]
expertMode = true
integrations = ["python_openai_ai_integrations:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["php"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Main App"

[[workflows.workflow]]
name = "Main App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python bank.py"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 4
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80
